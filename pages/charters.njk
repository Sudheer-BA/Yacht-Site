<section class="charters-hero charters-hero--with-bg">
  <div class="about-hero-overlay"></div>
  <div class="charters-hero-content">
    <h1>Private Yacht Charters Aboard Knot Caught Slippin</h1>
    <p class="charters-hero-tagline">Fully crewed charters from Fort Lauderdale to South Florida, the Keys, and the Bahamas.</p>
    <a href="tel:{{ site.phoneTel }}" class="charters-hero-cta">Call to Reserve</a>
  </div>
</section>

<section class="charters-rates-section">
  <div class="charters-rates-inner">
    <h2 class="section-heading">Charter Durations & Rates</h2>
    <p class="charters-rates-note">Minimum 4 hours. Fuel may vary by destination.</p>
    <div class="charters-rate-cards">
      <article class="charters-rate-card">
        <span class="charters-rate-card-duration">4 Hours</span>
        <span class="charters-rate-card-price">$5,000</span>
        <span class="charters-rate-card-label">Starting price</span>
      </article>
      <article class="charters-rate-card">
        <span class="charters-rate-card-duration">6 Hours</span>
        <span class="charters-rate-card-price">$6,000</span>
        <span class="charters-rate-card-label">Starting price</span>
      </article>
      <article class="charters-rate-card">
        <span class="charters-rate-card-duration">8 Hours</span>
        <span class="charters-rate-card-price">$7,000</span>
        <span class="charters-rate-card-label">Starting price</span>
      </article>
      <article class="charters-rate-card charters-rate-card--weekly">
        <span class="charters-rate-card-duration">Weekly</span>
        <span class="charters-rate-card-price">$42,000</span>
        <span class="charters-rate-card-label">Extended escape</span>
      </article>
    </div>
  </div>
</section>

<section class="destinations-section charters-destinations">
  <h2 class="section-heading">Destinations & Flexibility</h2>
  <p class="charters-dest-intro">Departing Fort Lauderdale. Your choice of experience:</p>
  <ul class="charters-dest-bullets">
    <li>Sandbar experiences</li>
    <li>Coastal cruising</li>
    <li>Waterfront dining</li>
    <li>Florida Keys</li>
    <li>Bahamas (weather permitting)</li>
  </ul>
  <div class="destinations-grid">
    <article class="destination-card">
      <div class="destination-image">
        <img src="{{ '/images/destinations/fort-lauderdale.png' | url }}" alt="Fort Lauderdale">
        <span class="destination-name">Fort Lauderdale</span>
      </div>
    </article>
    <article class="destination-card">
      <div class="destination-image">
        <img src="{{ '/images/destinations/miami.png' | url }}" alt="Miami">
        <span class="destination-name">Miami</span>
      </div>
    </article>
    <article class="destination-card">
      <div class="destination-image">
        <img src="{{ '/images/destinations/key-west.png' | url }}" alt="Key West">
        <span class="destination-name">Key West</span>
      </div>
    </article>
    <article class="destination-card">
      <div class="destination-image">
        <img src="{{ '/images/destinations/bahamas.png' | url }}" alt="The Bahamas">
        <span class="destination-name">The Bahamas</span>
      </div>
    </article>
  </div>
  <div class="destinations-cta">
    <a href="{{ '/contact/' | url }}" class="cta-button">Plan Your Route</a>
  </div>
</section>

<section class="charters-included-section">
  <div class="charters-included-inner">
    <h2 class="section-heading">What’s Included</h2>
    <ul class="charters-included-grid">
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Licensed Captain and Stewardess</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Beverages (Water, Coke, Diet Coke, Sprite — alternatives on request)</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Ice</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>WiFi</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Bluetooth Audio System</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Floating Mattress</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Towels</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Stabilizers</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Snorkeling gear (fins, masks, snorkels)</li>
      <li class="charters-included-item"><span class="charters-check" aria-hidden="true"></span>Local idle fuel</li>
    </ul>
  </div>
</section>

